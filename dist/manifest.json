{
  "manifest_version": 3,
  "name": "Smart Glossary",
  "version": "1.0.0",
  "description": "AI-powered glossary for web pages",
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage"
  ],
  "background": {
    "service_worker": "background/context-menu.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/selection-handler.js"],
      "run_at": "document_idle"
    }
  ]
}